{
  "name": "ogpreview-app",
  "type": "module",
  "private": true,
  "version": "1.0.28",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\"",
    "typecheck": "npx nuxt typecheck",
    "ship": "npx tsx tools/ship.ts",
    "generate:favicons": "npx tsx tools/generate-favicons.ts",
    "prelint": "pnpm run build:plugins",
    "lint": "eslint .",
    "quality": "pnpm run quality:fix && pnpm run quality:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute ogpreview-app-db --local --file=drizzle/0000_initial_schema.sql",
    "db:studio": "drizzle-kit studio",
    "init": "npx jiti tools/init.ts",
    "setup": "npx jiti tools/setup-analytics.ts status",
    "setup:all": "npx jiti tools/setup-analytics.ts all",
    "setup:gsc": "npx jiti tools/setup-analytics.ts gsc",
    "setup:gsc:verify": "npx jiti tools/setup-analytics.ts gsc:verify",
    "setup:ga": "npx jiti tools/setup-analytics.ts ga",
    "setup:indexnow": "npx jiti tools/setup-analytics.ts indexnow",
    "submit:indexnow": "npx tsx tools/indexnow.ts",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "predev": "node tools/check-setup.cjs",
    "prebuild": "node tools/check-setup.cjs",
    "preship": "node tools/check-setup.cjs && pnpm install --frozen-lockfile && npx tsx tools/check-drift-ci.ts && npx tsx tools/check-sync-health.ts && pnpm run quality:check",
    "update-layer": "npx tsx tools/update-layer.ts",
    "predeploy": "node tools/check-setup.cjs",
    "format": "prettier --write \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "tail": "npx tsx tools/tail.ts",
    "check:sync-health": "npx tsx tools/check-sync-health.ts",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install && pnpm run db:ready:all",
    "dev:kill": "sh scripts/dev-kill.sh",
    "quality:fix": "turbo run lint --force -- --fix && pnpm run format",
    "sync-template": "npx tsx tools/sync-template.ts .",
    "hooks:install": "node tools/install-git-hooks.cjs",
    "guardrails:repo": "npx tsx tools/check-guardrails.ts",
    "quality:check": "pnpm run guardrails:repo && turbo run quality --filter='./apps/*'",
    "check": "pnpm run quality:check",
    "skills:link": "npx tsx tools/ensure-skills-links.ts",
    "cleanup:node-leaks": "sh scripts/cleanup-node-leaks.sh"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/seo": "^3.4.0",
    "@vercel/og": "^0.9.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.0",
    "nuxt-og-image": "^5.1.13",
    "posthog-js": "^1.205.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.94",
    "@iconify-json/simple-icons": "^1.2.71",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.20.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.12"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3",
      "@cloudflare/unenv-preset": "2.12.1",
      "nuxt-og-image": "6.0.0-beta.47",
      "@takumi-rs/core": ">=0.70.1",
      "@takumi-rs/wasm": ">=0.70.1",
      "@cloudflare/workers-types": "4.20260307.1",
      "@typescript-eslint/utils": "^8.57.0",
      "@nuxt/eslint": "^1.15.2",
      "eslint-plugin-unicorn": "^63.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "eslint",
        "citty",
        "@cloudflare/workers-types"
      ]
    }
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.14.0"
  },
  "packageManager": "pnpm@10.28.0"
}
